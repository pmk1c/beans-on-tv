{
  "cli": {
    "appVersionSource": "remote",
    "version": ">= 7.1.1",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "base": {
      "node": "24.15.0",
      "autoIncrement": true,
      "env": {
        "EXPO_TV": "1",
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      }
    },
    "development": {
      "extends": "base",
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal"
    },
    "production": {
      "extends": "base",
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "8G26T3SC9P",
        "ascAppId": "1671815295"
      }
    }
  }
}
