{
  "name": "beans-on-tv",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_TV=1 expo start",
    "android": "EXPO_TV=1 expo run:android --device",
    "ios": "EXPO_TV=1 expo run:ios",
    "lint": "expo lint",
    "tsc": "tsc",
    "prebuild": "EXPO_TV=1 expo prebuild --clean",
    "check-all": "npm run lint && tsc",
    "eas-build-post-install": "check-all",
    "prepare": "vp config"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/native": "^7.1.33",
    "@redux-devtools/remote": "^0.9.5",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/react-native": "~7.11.0",
    "date-fns": "^3.6.0",
    "expo": "^55.0.23",
    "expo-application": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.32",
    "expo-font": "~55.0.7",
    "expo-image": "~55.0.10",
    "expo-insights": "~55.0.16",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.17",
    "expo-updates": "~55.0.21",
    "expo-video": "~55.0.16",
    "react": "19.2.0",
    "react-native": "npm:react-native-tvos@0.76.1-0",
    "react-native-pixel-perfect": "^1.0.2",
    "react-redux": "^9.2.0",
    "redux-devtools-expo-dev-plugin": "^0.2.1",
    "socket.io-client": "v2-latest"
  },
  "devDependencies": {
    "@react-native-tvos/config-tv": "^0.1.6",
    "@types/react": "~19.2.14",
    "@types/socket.io-client": "1.4.36",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite-plus": "latest"
  },
  "overrides": {
    "@sentry/react-native": {
      "react-native": "$react-native"
    },
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@11.0.9",
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  }
}
