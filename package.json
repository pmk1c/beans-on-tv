{
  "name": "beans-on-tv",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "EXPO_TV=1 expo start",
    "android": "EXPO_TV=1 expo run:android --device",
    "ios": "EXPO_TV=1 expo run:ios",
    "lint": "expo lint",
    "tsc": "tsc",
    "prebuild": "EXPO_TV=1 expo prebuild --clean",
    "check-all": "npm run lint && tsc",
    "eas-build-post-install": "check-all"
  },
  "overrides": {
    "@sentry/react-native": {
      "react-native": "$react-native"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-navigation/native": "^7.1.17",
    "@redux-devtools/remote": "^0.9.3",
    "@reduxjs/toolkit": "^2.0.1",
    "@sentry/react-native": "^6.1.0",
    "date-fns": "^3.1.0",
    "expo": "52.0.3",
    "expo-application": "~6.0.1",
    "expo-constants": "~17.0.2",
    "expo-font": "~13.0.1",
    "expo-image": "2.0.0-preview.0",
    "expo-insights": "~0.8.1",
    "expo-linking": "~7.0.2",
    "expo-router": "4.0.2",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.7",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.2",
    "expo-updates": "~0.26.5",
    "expo-video": "~2.0.0-preview.0",
    "react": "18.3.1",
    "react-native": "npm:react-native-tvos@0.76.1-0",
    "react-native-pixel-perfect": "^1.0.2",
    "react-redux": "^9.0.4",
    "redux-devtools-expo-dev-plugin": "^0.2.1",
    "socket.io-client": "v2-latest"
  },
  "devDependencies": {
    "@react-native-tvos/config-tv": "^0.1.0",
    "@types/react": "~18.3.12",
    "@types/socket.io-client": "1.4.36",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  },
  "private": true
}
