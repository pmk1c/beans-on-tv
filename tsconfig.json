{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "moduleSuffixes": [".ios", ".android", ".native", ".web", ""],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "babel.config.js",
    "expo-env.d.ts",
    "metro.config.js"
  ]
}
